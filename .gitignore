# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# impeccable-ignore-start
.impeccable/*
!.impeccable/config.json
!.impeccable/live/
.impeccable/live/*
!.impeccable/live/config.json
!.impeccable/design.json
!.impeccable/critique/
# impeccable-ignore-end

# session scratch (not part of the app)
.superpowers/

# local agent tooling / config (not part of the app)
.claude/

# internal planning + spec docs (kept local, not published)
docs/superpowers/

# throwaway diagnostic probe
scripts/diagnose-longevity.ts
